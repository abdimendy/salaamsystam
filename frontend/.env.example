# API URL for production (include /api)
VITE_API_URL=https://your-api.onrender.com/api

# --- Deploy frontend (Vercel) ---
# 1. Push repo to GitHub
# 2. https://vercel.com → Import → root: frontend
# 3. Environment variable: VITE_API_URL = https://YOUR-RENDER-API.onrender.com/api
# 4. Deploy → copy URL (e.g. https://yellowbook.vercel.app)
# 5. On Render API service set FRONTEND_URL to that Vercel URL
