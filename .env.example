# PostgreSQL WEB (Neon / Supabase / Render) — copy to .env and fill in
# Neon: https://neon.tech → Create project → Connection string (pooled)
# Supabase: Project Settings → Database → URI
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# API (local)
# Postman base URL: http://localhost:5261/api
# Login: admin / Admin@123

# Vercel (optional): point frontend proxy to your live API
# BACKEND_URL=https://yellowbook-api.onrender.com

# Cloudinary — image storage (https://cloudinary.com/console)
# Option A: single URL (recommended)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Option B: separate keys
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
