# Production API (with or without /api — app normalizes to .../api)
VITE_API_URL=https://yellowbook-api.onrender.com

# --- Deploy frontend (Vercel) ---
# 1. Push repo to GitHub
# 2. https://vercel.com → Import → root directory: repo root (uses vercel.json)
# 3. Environment variable: VITE_API_URL = https://yellowbook-api.onrender.com
# 4. Optional runtime override: frontend/public/config.json → { "apiUrl": "https://..." }
# 4. Deploy → copy URL (e.g. https://yellowbook.vercel.app)
# 5. On Render API service set FRONTEND_URL to that Vercel URL
