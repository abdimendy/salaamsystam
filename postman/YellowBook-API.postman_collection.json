{
  "info": {
    "_postman_id": "yellowbook-api-collection",
    "name": "Yellow Book API",
    "description": "Yellow Book Telephone Directory API — Categories, Businesses, Auth, Health.\n\n1. Import this collection + YellowBook-Local environment in Postman.\n2. Select the **Yellow Book - Local** environment.\n3. Run **Auth → Login** first (optional; endpoints are anonymous).\n4. Use **Categories** then **Businesses** folders (CRUD).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5261"
    },
    {
      "key": "categoryId",
      "value": "1"
    },
    {
      "key": "businessId",
      "value": "1"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Checks API status and PostgreSQL connection."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.environment.set('token', json.token);",
                  "    console.log('Token saved for', json.username);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Default dev credentials. Saves JWT to `token` variable."
          },
          "response": []
        },
        {
          "name": "Me (current user)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Requires Bearer token from Login."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories"]
            }
          },
          "response": []
        },
        {
          "name": "Get Category By Id",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "{{categoryId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('categoryId', String(json.id));",
                  "    pm.environment.set('categoryId', String(json.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Technology\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories"]
            },
            "description": "Name: 2–100 characters, unique."
          },
          "response": []
        },
        {
          "name": "Update Category",
          "request": {
            "auth": { "type": "noauth" },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Technology & IT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "{{categoryId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Category",
          "request": {
            "auth": { "type": "noauth" },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/categories/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categories", "{{categoryId}}"]
            },
            "description": "Fails with 404 if category has businesses."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Businesses",
      "item": [
        {
          "name": "Get All Businesses",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/businesses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "businesses"]
            }
          },
          "response": []
        },
        {
          "name": "Get Business By Id",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/businesses/{{businessId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "businesses", "{{businessId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Create Business",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('businessId', String(json.id));",
                  "    pm.environment.set('businessId', String(json.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"City Tech Solutions\",\n  \"phone\": \"+1-555-9999\",\n  \"email\": \"info@citytech.com\",\n  \"address\": \"99 Innovation Drive, Suite 200\",\n  \"description\": \"IT consulting and support services.\",\n  \"categoryId\": {{categoryId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/businesses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "businesses"]
            },
            "description": "Use a valid `categoryId` (1–5 seeded, or from Create Category)."
          },
          "response": []
        },
        {
          "name": "Update Business",
          "request": {
            "auth": { "type": "noauth" },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"City Tech Solutions (Updated)\",\n  \"phone\": \"+1-555-9998\",\n  \"email\": \"contact@citytech.com\",\n  \"address\": \"99 Innovation Drive, Suite 300\",\n  \"description\": \"Updated description.\",\n  \"categoryId\": {{categoryId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/businesses/{{businessId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "businesses", "{{businessId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Business",
          "request": {
            "auth": { "type": "noauth" },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/businesses/{{businessId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "businesses", "{{businessId}}"]
            },
            "description": "Returns 204 No Content on success."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dashboard", "stats"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
